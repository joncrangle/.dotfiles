{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"mlx": {
			"npm": "@ai-sdk/openai-compatible",
			"name": "MLX",
			"options": {
				"baseURL": "http://127.0.0.1:8081/v1",
			},
			"models": {
				"MLX-Qwopus3.5-9B-v3-4bit": {
					"name": "Qwopus 9B v3 (local)",
				},
				"gemma-4-e4b-it-4bit": {
					"name": "Gemma 4 E4B (local)",
				},
			},
		},
	},
	"enabled_providers": [
		"cerebras",
		"google",
		"opencode",
		"mlx"
	],
	"share": "manual",
	"permission": {
		"doom_loop": "ask",
	},
	"autoupdate": false,
	"small_model": "opencode/minimax-m2.5-free",
	"agent": {
		"explore": {
			"disable": true,
		},
		"general": {
			"disable": true,
		},
	},
	"plugin": [
		"@tarquinen/opencode-dcp@latest"
	],
	"mcp": {
		"websearch": {
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp",
			"enabled": false,
		},
		"playwriter": {
			"type": "local",
			"command": [
				"bunx",
				"playwriter@latest"
			],
			"enabled": false,
		},
	},
}
